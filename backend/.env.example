PORT=3000

# In docker-compose: host = postgres (the service name). Locally: localhost.
DATABASE_URL=postgresql://emailtracker:CHANGE_ME@postgres:5432/email_tracker

# Must be ≥32 random chars. Generate: openssl rand -hex 32
HMAC_SECRET=CHANGE_ME
EMAIL_HASH_SECRET=CHANGE_ME

# Production: https://track.yourdomain.com
BACKEND_URL=http://localhost:3000
